  m_Script: {fileID: 11500000, guid: 31e0926c9502e2e49bece8e62d635eb9, type: 3}
  m_Name: SO_JoinFailureMessageCatalog
  m_EditorClassIdentifier: Assembly-CSharp::MultiplayerJoinFailureMessageCatalog
  _fallbackUseTitle: 1
  _fallbackTitle: "\uC811\uC18D \uC2E4\uD328"
  _fallbackBody: "\uC138\uC158 \uC785\uC7A5\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4.
    \uC7A0\uC2DC \uD6C4 \uB2E4\uC2DC \uC2DC\uB3C4\uD574 \uC8FC\uC138\uC694."
  _fallbackAutoClose: 0
  _fallbackAutoCloseDelaySeconds: 0
  _fallbackUseManualCloseButton: 1
  _entries:
  - FailureType: 0
    UseTitle: 0
    Title: 
    Body: 
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 1
    UseTitle: 1
    Title: "\uCF54\uB4DC \uC785\uB825 \uD544\uC694(Join Code Empty)"
    Body: "\uCC38\uAC00 \uCF54\uB4DC\uB97C \uC785\uB825\uD574\uC57C \uD569\uB2C8\uB2E4."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 2
    UseTitle: 1
    Title: "\uC138\uC158 \uC5C6\uC74C(Session Not Found)"
    Body: "\uC785\uB825\uD55C \uCF54\uB4DC\uC5D0 \uD574\uB2F9\uD558\uB294 \uC138\uC158\uC744
      \uCC3E\uC744 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uCF54\uB4DC\uB97C \uB2E4\uC2DC
      \uD655\uC778\uD558\uC138\uC694."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 3
    UseTitle: 1
    Title: "\uC785\uC7A5 \uBD88\uAC00(Session Full)"
    Body: "\uD574\uB2F9 \uC138\uC158\uC740 \uC774\uBBF8 \uC778\uC6D0\uC774 \uAC00\uB4DD
      \uCC3C\uC2B5\uB2C8\uB2E4."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 4
    UseTitle: 1
    Title: "\uC785\uC7A5 \uBD88\uAC00(Stage In Progress)"
    Body: "\uAC8C\uC784\uC774 \uC774\uBBF8 \uC9C4\uD589 \uC911\uC785\uB2C8\uB2E4.
      \uD604\uC7AC \uC138\uC158\uC5D0\uB294 \uCC38\uC5EC\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 5
    UseTitle: 1
    Title: "\uC798\uBABB\uB41C \uCF54\uB4DC(Invalid Join Code)"
    Body: "\uCC38\uAC00 \uCF54\uB4DC \uD615\uC2DD\uC774 \uC62C\uBC14\uB974\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC \uC785\uB825\uD558\uC138\uC694."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 6
    UseTitle: 1
    Title: "\uB124\uD2B8\uC6CC\uD06C \uC624\uB958(Network Unavailable)"
    Body: "\uB124\uD2B8\uC6CC\uD06C \uC5F0\uACB0\uC744 \uD655\uC778\uD558\uC138\uC694.
      \uC778\uD130\uB137 \uC0C1\uD0DC\uAC00 \uBD88\uC548\uC815\uD569\uB2C8\uB2E4."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 7
    UseTitle: 1
    Title: "\uC11C\uBE44\uC2A4 \uC624\uB958(Service Initialization Failed)"
    Body: "\uAC8C\uC784 \uC11C\uBE44\uC2A4 \uCD08\uAE30\uD654\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4.
      \uC7A0\uC2DC \uD6C4 \uB2E4\uC2DC \uC2DC\uB3C4\uD558\uC138\uC694."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 8
    UseTitle: 1
    Title: "\uC778\uC99D \uC2E4\uD328(Authentication Failed)"
    Body: "\uB85C\uADF8\uC778 \uC0C1\uD0DC\uB97C \uD655\uC778\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uB85C\uADF8\uC778 \uD6C4 \uC2DC\uB3C4\uD558\uC138\uC694."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 9
    UseTitle: 1
    Title: "\uC785\uC7A5 \uAC70\uBD80(Admission Denied)"
    Body: "\uC138\uC158\uC5D0\uC11C \uC785\uC7A5\uC774 \uAC70\uBD80\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 10
    UseTitle: 1
    Title: "\uC5F0\uACB0 \uC2E4\uD328(Start Client Failed)"
    Body: "\uC11C\uBC84\uC5D0 \uC5F0\uACB0\uD558\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uC2DC\uB3C4\uD558\uC138\uC694."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
  - FailureType: 99
    UseTitle: 1
    Title: "\uC54C \uC218 \uC5C6\uB294 \uC624\uB958(Unknown)"
    Body: "\uBB38\uC81C\uAC00 \uBC1C\uC0DD\uD588\uC2B5\uB2C8\uB2E4. \uC7A0\uC2DC
      \uD6C4 \uB2E4\uC2DC \uC2DC\uB3C4\uD558\uC138\uC694."
    AutoClose: 0
    AutoCloseDelaySeconds: 0
    UseManualCloseButton: 1
